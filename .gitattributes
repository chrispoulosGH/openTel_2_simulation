* text=auto

# Keep scripts with explicit line endings
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat common binaries as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.jar binary
*.exe binary
*.dll binary
*.pyd binary
*.xls binary
*.xlsx binary
